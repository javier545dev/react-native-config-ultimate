{
  "name": "react-native-config-ultimate",
  "title": "React Native Config Ultimate",
  "version": "0.0.7",
  "description": "Config that works. A community-maintained fork of react-native-ultimate-config.",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec",
    "!src/**/*.spec.ts",
    "!src/test_outputs",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-config-ultimate-example",
    "build": "bob build && node -e \"const fs=require('fs');const f='lib/commonjs/cli.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!')){fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "npm run build",
    "prepack": "printf '#error \"react-native-config-ultimate: ConfigValues.h not generated. Run: npx rncu .env from your project root before building iOS.\\n\"' > ios/ConfigValues.h",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint \"src/**/*.{js,ts,tsx}\" --max-warnings=0"
  },
  "bin": {
    "rncu": "./lib/commonjs/cli.js"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "12factor",
    "12factorapp",
    "dotenv",
    "env",
    "environment",
    "config",
    "xcconfig",
    "gradle",
    "objective-c",
    "swift",
    "java",
    "kotlin",
    "typescript",
    "yaml",
    "new-architecture",
    "turbomodules"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/javier545dev/react-native-config-ultimate.git"
  },
  "author": {
    "name": "Javier Fuentes",
    "email": "javierfuentes545@gmail.com"
  },
  "contributors": [
    {
      "name": "Max Komarychev",
      "email": "maxkomarychev@gmail.com",
      "url": "https://github.com/maxkomarychev"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/javier545dev/react-native-config-ultimate/issues"
  },
  "homepage": "https://github.com/javier545dev/react-native-config-ultimate#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.0",
    "@types/yargs": "^17.0.35",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-builder-bob": "^0.40.18",
    "ts-jest": "^29.2.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "dependencies": {
    "chokidar": "4.0.3",
    "dotenv": "16.6.1",
    "dotenv-expand": "^12.0.3",
    "handlebars": "^4.7.7",
    "js-yaml": "^4",
    "yargs": "^17"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  },
  "codegenConfig": {
    "name": "RNUltimateConfigSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.reactnativeultimateconfig"
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
