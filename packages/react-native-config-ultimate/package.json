{
  "name": "react-native-config-ultimate",
  "title": "React Native Config Ultimate",
  "version": "0.0.1",
  "description": "Config that works. A community-maintained fork of react-native-ultimate-config.",
  "main": "index.js",
  "react-native": "index.js",
  "browser": "index.web.js",
  "types": "index.d.ts",
  "files": [
    "src/*.js",
    "src/*.ts",
    "src/templates",
    "index.js",
    "index.ts",
    "override.js",
    "ios/UltimateConfig.{h,mm}",
    "ios/ConfigValues.h",
    "ios/UltimateConfig.xcodeproj/project.pbxproj",
    "android/src",
    "android/build.gradle",
    "android/rncu.gradle",
    "react-native-config-ultimate.podspec"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "pretest": "tsc",
    "test": "jest",
    "prepack": "echo '#error \"invoke bin.js with env file before compiling native project\"' > ios/ConfigValues.h && echo 'module.exports = {};' > override.js",
    "lint": "eslint src/**/*.ts index.ts --max-warnings=0",
    "format": "prettier --write src/**/*.ts index.ts"
  },
  "bin": {
    "rncu": "./bin.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/javier545dev/react-native-config-ultimate.git",
    "baseUrl": "https://github.com/javier545dev/react-native-config-ultimate"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "12factor",
    "12factorapp",
    "dotenv",
    "env",
    "environment",
    "config",
    "xcconfig",
    "gradle",
    "objective-c",
    "java",
    "typescript"
  ],
  "author": {
    "name": "Javier Fuentes",
    "email": "javierfuentes545@gmail.com"
  },
  "contributors": [
    {
      "name": "Max Komarychev",
      "email": "maxkomarychev@gmail.com",
      "url": "https://github.com/maxkomarychev"
    }
  ],
  "license": "MIT",
  "licenseFilename": "LICENSE",
  "readmeFilename": "README.md",
  "peerDependencies": {
    "react-native": ">=0.60.0-rc.0 <1.0.x"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-native": "0.79.5",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">= 18.0.0"
  },
  "dependencies": {
    "chokidar": "4.0.3",
    "dotenv": "16.6.1",
    "dotenv-expand": "^12.0.3",
    "handlebars": "^4.7.7",
    "js-yaml": "^4",
    "yargs": "^17"
  },
  "resolutions": {
    "logkitty": "^0.7.1",
    "lodash": "^4.17.19"
  },
  "codegenConfig": {
    "name": "RNUltimateConfigSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.reactnativeultimateconfig"
    }
  }
}
