{
  "name": "root",
  "private": true,
  "scripts": {
    "test": "lerna run test --scope=react-native-ultimate-config",
    "pods": "cd packages/example/ios && pod install",
    "example:env": "lerna run rnuc --scope=example -- -- .env",
    "example:start": "lerna run start --scope=example",
    "example:ios": "lerna run ios --scope=example",
    "example:android": "lerna run android --scope=example",
    "example:web:env": "lerna run rnuc --scope=example-web -- -- .env",
    "example:web:start": "lerna run start --scope=example-web",
    "version": "cd packages/react-native-ultimate-config; npx standard-version"
  },
  "devDependencies": {
    "lerna": "^9.0.4"
  }
}
