{
  "name": "root",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "lerna run build --scope=react-native-config-ultimate",
    "test": "lerna run test --scope=react-native-config-ultimate",
    "lint": "lerna run lint --scope=react-native-config-ultimate",
    "example:setup": "npm run build && npm run example:env && npm run pods",
    "example:env": "lerna run rncu --scope=example -- -- .env",
    "example:env:watch": "lerna run rncu --scope=example -- -- .env --watch",
    "example:start": "lerna run start --scope=example",
    "example:ios": "lerna run ios --scope=example",
    "example:android": "lerna run android --scope=example",
    "pods": "cd packages/example/ios && pod install",
    "example:web:setup": "npm run build && npm run example:web:env",
    "example:web:env": "lerna run rncu --scope=example-web -- -- .env",
    "example:web:start": "lerna run start --scope=example-web",
    "version": "cd packages/react-native-config-ultimate && npx standard-version"
  },
  "devDependencies": {
    "lerna": "^9.0.4"
  }
}
